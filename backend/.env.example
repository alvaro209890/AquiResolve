NODE_ENV=development
PORT=3000
PAGARME_BASE_URL=https://api.pagar.me/core/v5
PAGARME_SECRET_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
CORS_ORIGIN=*

# Cron de expiração de pedidos
CRON_SECRET=

# Webhook Pagar.me — segredo configurado no dashboard da Pagar.me junto com a URL
# https://aquiresolve.onrender.com/api/payments/webhook/pagarme
# Aceita HMAC-SHA256/SHA1 do corpo, Basic/Bearer auth ou header estático (ver src/utils/webhook-auth.js).
# Vazio = webhook aceito SEM validação (só até configurar).
PAGARME_WEBHOOK_SECRET=
