rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════════
    // HELPERS — autenticação e papéis
    // ═══════════════════════════════════════════════════════════════════════════

    // Usado pelo app mobile
    function isSignedIn() {
      return request.auth != null;
    }

    // Alias usado no dashboard admin
    function isAuthenticated() {
      return isSignedIn();
    }

    // Admin/operador via custom claim
    //   admin.auth().setCustomUserClaims(uid, { role: 'admin' })
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'operador'
      );
    }

    // Prestador autenticado no app mobile
    function isProvider() {
      return isSignedIn() && (
        request.auth.token.role == 'prestador' ||
        request.auth.token.role == 'provider'
      );
    }

    // Cliente autenticado no app mobile
    function isClient() {
      return isSignedIn() && (
        request.auth.token.role == 'cliente' ||
        request.auth.token.role == 'client'
      );
    }

    function isProviderOrAdmin() {
      return isProvider() || isAdmin();
    }

    // Dono do documento identificado pelo uid
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // HELPERS — validação de pedidos (app mobile — lógica exata preservada)
    // ═══════════════════════════════════════════════════════════════════════════

    function isOrderClient() {
      return isSignedIn() && resource.data.clientId == request.auth.uid;
    }

    function isOrderAssignedProvider() {
      return isSignedIn() && resource.data.assignedProvider == request.auth.uid;
    }

    function orderDeleteAllowed() {
      return isAdmin() || (isSignedIn() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.assignedProvider == request.auth.uid ||
        resource.data.clienteId == request.auth.uid
      ));
    }

    function orderPriceFieldsUnchanged() {
      return request.resource.data.estimatedPrice == resource.data.estimatedPrice
        && request.resource.data.providerCommission == resource.data.providerCommission;
    }

    function orderSensitiveAssignmentFieldsUnchanged() {
      return request.resource.data.assignedProvider == resource.data.assignedProvider
        && request.resource.data.assignedProviderName == resource.data.assignedProviderName
        && request.resource.data.clientVerificationCode == resource.data.clientVerificationCode
        && request.resource.data.providerVerificationCode == resource.data.providerVerificationCode;
    }

    function validOrderCreate() {
      return isSignedIn()
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.status == 'awaiting_payment'
        && request.resource.data.paymentStatus == 'awaiting_payment'
        && request.resource.data.estimatedPrice is number
        && request.resource.data.estimatedPrice > 0
        && request.resource.data.providerCommission is number
        && request.resource.data.providerCommission >= 0
        && request.resource.data.keys().hasAll([
          'clientId', 'clientName', 'protocol', 'serviceType', 'serviceName',
          'description', 'address', 'city', 'state', 'status', 'paymentStatus',
          'estimatedPrice', 'providerCommission', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'clientId', 'clientName', 'clientEmail', 'clientPhone', 'protocol',
          'serviceType', 'serviceName', 'description', 'address', 'zipCode',
          'complement', 'city', 'state', 'coordinates', 'scheduledDate',
          'preferredTimeSlot', 'images', 'cartCheckoutCode', 'cartItemId',
          'status', 'paymentStatus', 'estimatedPrice', 'finalPrice',
          'cartDiscountPercent', 'providerCommission', 'createdAt', 'updatedAt'
        ]);
    }

    function validClientOrderUpdate() {
      return isOrderClient()
        && orderPriceFieldsUnchanged()
        && orderSensitiveAssignmentFieldsUnchanged()
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['images', 'updatedAt'])
          || (
            request.resource.data.status == 'cancelled'
            && request.resource.data.cancelledBy == 'client'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'cancelledAt', 'cancelledBy', 'cancellationReason',
              'updatedAt', 'refundStatus', 'refundRequestedAt'
            ])
          )
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'clientCompletionConfirmed', 'status', 'completedAt',
            'settlementStatus', 'settlementRequestedAt', 'updatedAt'
          ])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'rating', 'review', 'detailedRatings', 'ratedAt', 'updatedAt'
          ])
        );
    }

    function validProviderAcceptUpdate() {
      return isSignedIn()
        && resource.data.status in ['distributing', 'pending', 'available']
        && (resource.data.assignedProvider == null || resource.data.assignedProvider == '')
        && request.resource.data.status == 'assigned'
        && request.resource.data.assignedProvider == request.auth.uid
        && request.resource.data.assignedProviderName is string
        && request.resource.data.clientVerificationCode is string
        && request.resource.data.providerVerificationCode is string
        && orderPriceFieldsUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'assignedProvider', 'assignedProviderName', 'status', 'assignedAt',
          'clientVerificationCode', 'providerVerificationCode',
          'verificationCodesGeneratedAt', 'updatedAt'
        ]);
    }

    function validProviderOrderUpdate() {
      return isOrderAssignedProvider()
        && orderPriceFieldsUnchanged()
        && (
          (
            resource.data.status == 'assigned'
            && request.resource.data.status == 'in_progress'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'startedAt', 'updatedAt'])
          )
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'providerCompletionConfirmed', 'clientCompletionConfirmed', 'status',
            'completedAt', 'settlementStatus', 'settlementRequestedAt', 'updatedAt'
          ])
          || (
            request.resource.data.status == 'cancelled'
            && request.resource.data.cancelledBy == 'provider'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'cancelledAt', 'cancelledBy', 'cancellationReason', 'updatedAt'
            ])
          )
        );
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // adminmaster (exclusivo do dashboard)
    // ═══════════════════════════════════════════════════════════════════════════

    // adminmaster: apenas Admin SDK pode ler/escrever (regras bloqueiam client SDK)
    match /adminmaster/{document=**} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Configurações do app (escrita via Admin SDK / dashboard)
    // ═══════════════════════════════════════════════════════════════════════════

    match /app_config/{configId} {
      allow read: if isSignedIn();
      allow write: if false; // Dashboard usa Admin SDK
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Usuários
    // ═══════════════════════════════════════════════════════════════════════════

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId;
      allow update: if isOwner(userId)
        && (request.resource.data.uid == userId || resource.data.uid == null);
      allow update: if isAdmin();
      allow delete: if isOwner(userId) || isAdmin();

      match /cashback_transactions/{txId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Prestadores
    // ═══════════════════════════════════════════════════════════════════════════

    match /providers/{providerId} {
      allow read: if isSignedIn();
      allow create: if isOwner(providerId)
        && request.resource.data.uid == providerId;
      allow update: if isOwner(providerId)
        && (request.resource.data.uid == providerId || resource.data.uid == null);
      allow delete: if isOwner(providerId) || isAdmin();
      // Dashboard: admin acesso total
      allow write: if isAdmin();
      // Dashboard: prestador atualiza apenas campos operacionais
      allow update: if isProvider()
        && request.auth.uid == providerId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['localizacao', 'status', 'online', 'ultimaAtualizacao', 'servicoAtual']);
    }

    match /provider_locations/{locationId} {
      allow read: if isAdmin();
      allow create, update: if isProvider();
    }

    match /provider_logins/{loginId} {
      allow read: if isAdmin();
      allow create: if isProvider();
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Documentos de prestadores
    // ═══════════════════════════════════════════════════════════════════════════

    match /provider_verifications/{verificationId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /provider_documents/{documentId} {
      allow read: if isAdmin();
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.providerId == request.auth.uid
      );
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.providerId == request.auth.uid
      );
      allow update: if isAdmin();
      allow update: if isSignedIn()
        && (resource.data.userId == request.auth.uid || resource.data.providerId == request.auth.uid)
        && (request.resource.data.userId == request.auth.uid || request.resource.data.providerId == request.auth.uid);
      allow delete: if isAdmin();
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.providerId == request.auth.uid
      );
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Dados bancários do prestador
    // ═══════════════════════════════════════════════════════════════════════════

    match /provider_bank_data/{docId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Pedidos (orders)
    // ═══════════════════════════════════════════════════════════════════════════

    match /orders/{orderId} {
      // App mobile: qualquer autenticado lê
      allow read: if isSignedIn();
      // App mobile: criação e atualizações granulares
      allow create: if validOrderCreate();
      allow update: if validClientOrderUpdate()
        || validProviderAcceptUpdate()
        || validProviderOrderUpdate();
      allow delete: if orderDeleteAllowed();

      // Dashboard: admin acesso total
      allow read, write: if isAdmin();
      // Dashboard: prestador (schema PT) — leitura e update de campos operacionais
      allow read: if isProvider() && (
        resource.data.prestadorId == request.auth.uid ||
        resource.data.get('assignedTechnician', {}).get('id', '') == request.auth.uid
      );
      allow update: if isProvider()
        && (
          resource.data.prestadorId == request.auth.uid ||
          resource.data.get('assignedTechnician', {}).get('id', '') == request.auth.uid
        )
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['serviceOperationalStatus', 'serviceTimestamps', 'serviceValidation',
                      'updatedAt', 'serviceCompletionFlags']);
      // Dashboard: cliente (schema PT)
      allow read: if isClient() && resource.data.clienteId == request.auth.uid;

      // ── Mensagens de chat (subcoleção) ────────────────────────────────────
      match /messages/{messageId} {
        // App mobile: qualquer autenticado lê e escreve
        allow read, write: if isSignedIn();
        // Dashboard: visibilidade granular
        allow read, write: if isAdmin();
        allow read: if isClient()
          && resource.data.clienteId == request.auth.uid
          && resource.data.visibility in ['public', 'admin_client'];
        allow read: if isProvider()
          && resource.data.visibility in ['public', 'admin_provider'];
        allow create: if isSignedIn()
          && request.resource.data.visibility == 'public'
          && request.resource.data.senderId == request.auth.uid;
      }

      // ── Eventos operacionais (subcoleção — append-only) ───────────────────
      match /operational_events/{eventId} {
        allow read: if isSignedIn();
        allow create: if isProviderOrAdmin();
        allow update, delete: if false;
      }

      // ── Checklists do serviço (subcoleção) ────────────────────────────────
      match /checklists/{checklistId} {
        allow read, write: if isAdmin();
        allow read: if isProvider() && resource.data.providerId == request.auth.uid;
        allow create: if isProvider() && request.resource.data.providerId == request.auth.uid;
        allow update: if isProvider()
          && resource.data.providerId == request.auth.uid
          && resource.data.status != 'concluido';
        allow read: if isClient()
          && get(/databases/$(database)/documents/orders/$(orderId)).data.clienteId == request.auth.uid;
      }
    }

    match /order_settlements/{settlementId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Templates de Checklist (dashboard)
    // ═══════════════════════════════════════════════════════════════════════════

    match /checklist_templates/{templateId} {
      allow read: if isSignedIn() && resource.data.ativo == true;
      allow read, write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Checklists top-level (app mobile)
    // ═══════════════════════════════════════════════════════════════════════════

    match /checklists/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.orderId == orderId;
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Chat
    // ═══════════════════════════════════════════════════════════════════════════

    // Chat rooms do app mobile (entre cliente e prestador)
    match /chatRooms/{chatRoomId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn()
        && resource.data.participants != null
        && resource.data.participants.hasAny([request.auth.uid]);
      allow create: if isSignedIn()
        && request.resource.data.participants != null
        && request.resource.data.participants.hasAny([request.auth.uid]);
      allow update: if isSignedIn()
        && resource.data.participants != null
        && resource.data.participants.hasAny([request.auth.uid]);
      allow delete: if isSignedIn()
        && resource.data.participants != null
        && resource.data.participants.hasAny([request.auth.uid]);
    }

    // Coleção legada ainda usada em rotinas de exclusão de conta
    match /chats/{chatId} {
      allow read, write: if isSignedIn();
    }

    // Chat de suporte do dashboard admin
    match /chatConversations/{conversationId} {
      allow read, write: if isAdmin();
      allow read, update: if isSignedIn()
        && request.auth.uid in resource.data.participantIds;
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participantIds;
    }

    match /chatMonitoring/{monitorId} {
      allow read, write: if isAdmin();
    }

    match /support_messages/{messageId} {
      allow read, write: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.senderId == request.auth.uid;
      allow read: if isSignedIn()
        && resource.data.senderId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Notificações
    // ═══════════════════════════════════════════════════════════════════════════

    match /notifications/{notificationId} {
      allow read, write: if isAdmin();
      // App mobile: userId como campo de destino
      allow read, update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    match /operationalAlerts/{alertId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn();
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Tokens FCM e dados do usuário no app
    // ═══════════════════════════════════════════════════════════════════════════

    match /userTokens/{userId} {
      allow read, write: if isAdmin();
      allow read, write: if isOwner(userId);
    }

    match /carts/{userId} {
      allow read, write: if isAdmin();
      allow read, write: if isOwner(userId);

      match /items/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /user_favorites/{favoriteId} {
      allow read, write: if isAdmin();
      allow read, update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    // App mobile usa clientId; dashboard usa userId — ambos cobertos
    match /saved_addresses/{addressId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn()
        && (resource.data.clientId == request.auth.uid || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && (request.resource.data.clientId == request.auth.uid || request.resource.data.userId == request.auth.uid);
      allow update: if isSignedIn()
        && (resource.data.clientId == request.auth.uid || resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn()
        && (resource.data.clientId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Catálogo de serviços
    // ═══════════════════════════════════════════════════════════════════════════

    match /service_categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /service_types/{typeId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /service_providers/{providerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /provider_reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.clientId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.clientId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /service_quotes/{quoteId} {
      allow read, write: if isAdmin();
      allow read: if isSignedIn();
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Financeiro (dashboard)
    // ═══════════════════════════════════════════════════════════════════════════

    match /transactions/{transactionId} {
      allow read, write: if isAdmin();
    }

    match /accounts/{accountId} {
      allow read, write: if isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Analytics e logs
    // ═══════════════════════════════════════════════════════════════════════════

    match /activities/{activityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }

    match /analytics_events/{eventId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      allow create: if isSignedIn();
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // LGPD
    // ═══════════════════════════════════════════════════════════════════════════

    match /lgpd_consents/{consentId} {
      allow read, write: if isAdmin();
      allow read: if isOwner(resource.data.userId);
      // Bug fix: create usa request.resource.data (documento ainda não existe)
      allow create: if isOwner(request.resource.data.userId);
    }

    match /lgpd_requests/{requestId} {
      allow read, write: if isAdmin();
      allow create: if isSignedIn();
      allow read: if isOwner(resource.data.userId);
    }

    // Configurações de privacidade
    match /privacy_settings/{userId} {
      allow read, write: if isAdmin();
      allow read, write: if isOwner(userId);
    }

    // Exportações de dados — lógica do app mobile preservada (userData.uid)
    match /data_exports/{exportId} {
      allow read, write: if isAdmin();
      allow create: if isSignedIn();
      allow read, delete: if isSignedIn()
        && resource.data.userData != null
        && resource.data.userData.uid == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Fallback — nega tudo que não foi explicitamente permitido acima
    // ═══════════════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
