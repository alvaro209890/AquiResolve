<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    tools:context=".ClientHomeActivity">

    <!-- App Bar elegante -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_color"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary_color"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end|center_vertical"
                android:layout_marginBottom="12dp">

                <!-- Botão Central AquiResolve (chat base ↔ cliente) com badge -->
                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp">

                    <ImageButton
                        android:id="@+id/btnCentralChat"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="@drawable/circle_background_primary"
                        android:src="@android:drawable/ic_dialog_email"
                        app:tint="@android:color/white"
                        android:contentDescription="Central AquiResolve" />

                    <TextView
                        android:id="@+id/tvCentralBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="top|end"
                        android:minWidth="16dp"
                        android:minHeight="16dp"
                        android:paddingHorizontal="4dp"
                        android:background="@color/secondary_color"
                        android:textColor="@android:color/white"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:visibility="gone"
                        tools:text="3" />

                </FrameLayout>

                <!-- Botão de notificações -->
                <ImageButton
                    android:id="@+id/btnNotifications"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/circle_background_primary"
                    android:src="@drawable/ic_notifications"
                    app:tint="@android:color/white"
                    android:contentDescription="Notificações" />

                <!-- Botão de carrinho -->
                <ImageButton
                    android:id="@+id/btnCart"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/circle_background_primary"
                    android:src="@drawable/ic_cart"
                    app:tint="@android:color/white"
                    android:contentDescription="Carrinho" />

                <!-- Botão de perfil -->
                <ImageButton
                    android:id="@+id/btnProfile"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/circle_background_primary"
                    android:src="@drawable/ic_person"
                    app:tint="@android:color/white"
                    android:contentDescription="Perfil" />

            </LinearLayout>

            <!-- Barra de pesquisa elegante -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/surface_color"
                app:strokeWidth="1dp"
                app:strokeColor="@color/gray_300">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/primary_color" />

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="O que você precisa hoje?"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/gray_500"
                        android:textSize="16sp" />

                    <ImageView
                        android:id="@+id/ivFilter"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:src="@drawable/ic_filter"
                        app:tint="@color/primary_color" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Conteúdo principal (pull-to-refresh recarrega as seções dinâmicas da Home) -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="96dp">

            <!-- Busca Inteligente: sugestões instantâneas do catálogo (escondida quando vazia) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/sectionSearchSuggestions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_color"
                app:strokeWidth="1dp"
                app:strokeColor="@color/gray_200"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="4dp">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvSearchSuggestions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_search_suggestion" />

                    <!-- Estado "sem resultado" com CTA (não deixa o cliente num beco sem saída) -->
                    <TextView
                        android:id="@+id/tvSearchEmptyCta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Não encontramos esse serviço. Toque para descrever ao Assistente 🤖 →"
                        android:textColor="@color/primary_color"
                        android:textSize="14sp"
                        android:background="?android:attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="16dp"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Carrossel de banners promocionais (gerenciado pelo painel; escondido quando vazio) -->
            <LinearLayout
                android:id="@+id/sectionBanners"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="20dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/bannerPager"
                    android:layout_width="match_parent"
                    android:layout_height="160dp" />

                <LinearLayout
                    android:id="@+id/bannerDots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp" />

            </LinearLayout>

            <!-- Saudação enxuta (1 linha) — o acesso ao serviço vem pela busca/categorias/banner -->
            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Olá! O que você precisa hoje?"
                android:textSize="22sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="20dp" />

            <!-- Seção de Categorias (nichos em scroll horizontal) -->
            <LinearLayout
                android:id="@+id/sectionCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvCategoriesTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Categorias"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCategories"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    tools:listitem="@layout/item_home_category"
                    tools:orientation="horizontal" />

            </LinearLayout>

            <!-- Card de cashback em destaque (logo após Categorias, na ordem Premium) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCashback"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/primary_color"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💸 Seu Cashback"
                            android:textSize="14sp"
                            android:textColor="@color/white"
                            android:alpha="0.85" />

                        <TextView
                            android:id="@+id/tvCashbackBalance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R$ 0,00"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="disponível para usar"
                            android:textSize="12sp"
                            android:textColor="@color/white"
                            android:alpha="0.75"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_arrow_right"
                        android:tint="@color/white"
                        android:alpha="0.8" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Combos Promocionais (vitrine — plano 03). GONE até haver combos ativos. -->
            <LinearLayout
                android:id="@+id/sectionCombos"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvCombosTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔥 Combos Promocionais"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCombos"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    tools:listitem="@layout/item_home_combo"
                    tools:orientation="horizontal" />

            </LinearLayout>

            <!-- Parceiros AquiResolve (vitrine — plano 04). GONE até haver parceiros ativos. -->
            <LinearLayout
                android:id="@+id/sectionPartners"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvPartnersTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🤝 Parceiros AquiResolve"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPartners"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    tools:listitem="@layout/item_partner"
                    tools:orientation="horizontal" />

            </LinearLayout>

            <!-- Seção de pedidos recentes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    android:id="@+id/tvRecentOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Seus Pedidos Recentes"
                    android:textSize="20sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Container dinâmico para pedidos recentes -->
                <LinearLayout
                    android:id="@+id/containerRecentOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Estado vazio (sem pedidos) -->
                <TextView
                    android:id="@+id/tvEmptyOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nenhum pedido ainda. Acesse a aba Serviços para solicitar um pedido."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="visible" />

            </LinearLayout>

            <!-- CTA do Assistente IA (plano 06) — fecha a Home como conveniência para indecisos -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAssistant"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/surface_color"
                app:strokeWidth="1dp"
                app:strokeColor="@color/gray_200"
                android:layout_marginBottom="24dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?android:attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="18dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🤖"
                        android:textSize="30sp"
                        android:layout_marginEnd="14dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Não sabe o nome do serviço?"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Descreva o problema e o Assistente AquiResolve encontra para você."
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"
                            android:lineSpacingExtra="2dp" />

                    </LinearLayout>

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/primary_color" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/surface_color"
        android:minHeight="64dp"
        app:elevation="8dp"
        app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
