<?xml version="1.0" encoding="utf-8"?>
<!--
  Detalhe do parceiro (plano 04). Banner/logo no topo, nome, descrição, benefício em destaque,
  cupom em "pill" com botão Copiar (quando coupon) e botão "Visitar site" (quando há url).
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Topo: voltar -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Voltar"
                app:tint="@color/text_primary" />

            <!-- Banner/logo -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/surface_color">

                <ImageView
                    android:id="@+id/ivPartnerBanner"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:scaleType="fitCenter"
                    android:padding="16dp"
                    android:contentDescription="@null" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvPartnerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="Leroy Merlin" />

            <!-- Benefício em destaque -->
            <TextView
                android:id="@+id/tvPartnerBenefit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_partner_benefit_badge"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="💰 10% OFF na primeira compra" />

            <TextView
                android:id="@+id/tvPartnerDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:lineSpacingExtra="3dp"
                tools:text="Materiais de construção e reforma com desconto para clientes AquiResolve." />

            <!--
              Aviso exibido apenas quando o benefício é discount ou cashback. Esses tipos são
              concedidos pelo parceiro, não pelo app — sem este aviso o usuário pode achar que
              recebe o benefício automaticamente ao contratar via AquiResolve.
            -->
            <TextView
                android:id="@+id/tvBenefitExplanation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@color/surface_warning"
                android:padding="12dp"
                android:textColor="@color/warning_text"
                android:textSize="13sp"
                android:lineSpacingExtra="2dp"
                android:visibility="gone" />

            <!-- Cupom (pill + copiar) -->
            <LinearLayout
                android:id="@+id/sectionCoupon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seu cupom"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_coupon_pill"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tvCouponCode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:letterSpacing="0.1"
                        android:textColor="@color/primary_color"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        tools:text="AQUI10" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCopyCoupon"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Copiar"
                        android:textSize="13sp"
                        app:icon="@drawable/ic_content_copy"
                        app:iconSize="16dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Visitar site -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVisitSite"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Visitar site do parceiro"
                android:textSize="16sp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                app:backgroundTint="@color/primary_color"
                app:cornerRadius="12dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
