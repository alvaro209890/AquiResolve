<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/dialog_success_background">

    <!-- Ícone de sucesso animado -->
    <FrameLayout
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/success_circle_background">

        <ImageView
            android:id="@+id/ivSuccessIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_check"
            app:tint="@color/white" />

    </FrameLayout>

    <!-- Título -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:gravity="center"
        android:text="🎉 Conta Criada!"
        android:textColor="@color/primary_color"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- Mensagem de sucesso -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:text="Sua conta foi criada com sucesso!"
        android:textColor="@color/text_primary"
        android:textSize="16sp" />

    <!-- Email do usuário -->
    <TextView
        android:id="@+id/tvEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:textStyle="italic" />

    <!-- Mensagem adicional -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:text="Agora você pode fazer login e começar a usar o aplicativo!"
        android:textColor="@color/text_secondary"
        android:textSize="14sp" />

    <!-- Botão de continuar -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Fazer Login"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/primary_color"
        app:cornerRadius="28dp"
        app:elevation="4dp"
        app:icon="@drawable/ic_arrow_right"
        app:iconGravity="end"
        app:iconPadding="8dp"
        app:iconTint="@color/white" />

</LinearLayout>
