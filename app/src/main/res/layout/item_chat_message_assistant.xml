<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="bottom"
    android:paddingVertical="4dp"
    android:paddingEnd="56dp">

    <!-- Avatar mini do bot -->
    <androidx.cardview.widget.CardView
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="2dp"
        app:cardCornerRadius="14dp"
        app:cardBackgroundColor="#FF9B40"
        app:cardElevation="0dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="🤖"
            android:textSize="14sp" />

    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/surface_color"
            app:strokeWidth="1dp"
            app:strokeColor="@color/gray_200"
            app:cardUseCompatPadding="false">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="260dp"
                    android:paddingHorizontal="14dp"
                    android:paddingTop="10dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:lineSpacingExtra="3dp" />

                <!-- Botão "Solicitar Serviço" (visível só quando a IA sugerir um nicho) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSolicitar"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="10dp"
                    android:text="Solicitar Serviço"
                    android:textSize="13sp"
                    android:visibility="gone"
                    app:cornerRadius="12dp"
                    app:icon="@drawable/ic_services"
                    app:iconSize="16dp"
                    app:backgroundTint="@color/primary_color"
                    android:textColor="@color/white" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</LinearLayout>
