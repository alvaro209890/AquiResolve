<?xml version="1.0" encoding="utf-8"?>
<!--
  Card do parceiro na seção horizontal "Parceiros AquiResolve" da Home (PartnerAdapter).
  Mesmo tamanho do card de combo (260dp de largura, imagem de 120dp no topo com centerCrop)
  para que parceiros e combos sejam exibidos com imagens do mesmo tamanho. Mostra a imagem do
  parceiro (banner, com fallback no logo), o nome e o rótulo de benefício em pill verde.
  O clique abre PartnerDetailActivity.
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/partnerCard"
    android:layout_width="260dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/surface_color"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Imagem do parceiro: mesma área do combo (120dp, centerCrop). -->
        <FrameLayout
            android:id="@+id/partnerImageHolder"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/surface_color">

            <ImageView
                android:id="@+id/ivPartnerLogo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@null" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/tvPartnerName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="Leroy Merlin" />

            <TextView
                android:id="@+id/tvPartnerBenefit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_partner_benefit_badge"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:gravity="center"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="💰 10% OFF" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
