<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color">

    <!-- Header do Cliente -->
    <LinearLayout
        android:id="@+id/headerSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="vertical"
        android:background="@color/primary_color"
        android:elevation="4dp">

        <!-- Barra superior -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <!-- Botão voltar -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:tint="@android:color/white"
                android:contentDescription="Voltar" />

            <!-- Informações do prestador -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/tvProviderName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nome do Prestador"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white" />

                <TextView
                    android:id="@+id/tvProviderStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🟢 Online"
                    android:textSize="14sp"
                    android:textColor="@android:color/white" />

            </LinearLayout>

            <!-- Foto do prestador -->
            <ImageView
                android:id="@+id/ivProviderPhoto"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_background"
                android:src="@drawable/ic_person"
                android:scaleType="centerCrop"
                android:visibility="gone" />

            <!-- Botão de informações -->
            <ImageButton
                android:id="@+id/btnProviderInfo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_info"
                android:tint="@android:color/white"
                android:contentDescription="Informações" />

        </LinearLayout>

        <!-- Informações do serviço -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@color/primary_dark">

            <TextView
                android:id="@+id/tvOrderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Título do Serviço"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/tvClientInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Você está conversando com o prestador"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:alpha="0.8" />

        </LinearLayout>

    </LinearLayout>

    <!-- Botões de ação do cliente -->
    <LinearLayout
        android:id="@+id/actionButtonsSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerSection"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/surface_color"
        android:elevation="2dp"
        android:visibility="gone">

        <!-- Botão de avaliação -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRate"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="⭐ Avaliar"
            android:textSize="12sp"
            app:cornerRadius="20dp"
            app:backgroundTint="@color/warning_color"
            style="@style/Widget.Material3.Button" />

        <!-- Botão de denúncia -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReport"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:text="🚨 Denunciar"
            android:textSize="12sp"
            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="10sp"
            app:autoSizeMaxTextSize="12sp"
            app:autoSizeStepGranularity="1sp"
            android:textColor="@android:color/white"
            app:cornerRadius="20dp"
            app:backgroundTint="@color/error_color"
            style="@style/Widget.Material3.Button" />

        <!-- Botão de finalizar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFinishService"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="✅ Finalizar"
            android:textSize="12sp"
            app:cornerRadius="20dp"
            app:backgroundTint="@color/success_color"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>

    <!-- Lista de mensagens -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewMessages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerSection"
        android:layout_above="@id/inputSection"
        android:background="@color/background_color"
        android:padding="8dp"
        android:scrollbars="vertical"
        android:clipToPadding="false" />

    <!-- Seção de input -->
    <LinearLayout
        android:id="@+id/inputSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:background="@color/surface_color"
        android:elevation="8dp">

        <!-- Input de mensagem -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- Botão de anexo -->
            <ImageButton
                android:id="@+id/btnAttach"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_attach"
                android:tint="@color/primary_color"
                android:contentDescription="Anexar" />

            <!-- Campo de texto -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:hint="Digite sua mensagem..."
                app:boxStrokeColor="@color/primary_color"
                app:hintTextColor="@color/primary_color"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:maxLines="4"
                    android:textColor="@color/text_primary" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Botão de enviar -->
            <ImageButton
                android:id="@+id/btnSend"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/circle_primary_background"
                android:src="@drawable/ic_send"
                android:tint="@android:color/white"
                android:enabled="false"
                android:contentDescription="Enviar" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
