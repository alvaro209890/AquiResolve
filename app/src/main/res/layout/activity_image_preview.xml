<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- ViewPager para as imagens -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- TabLayout para indicadores -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="80dp"
        android:background="@color/transparent"
        app:tabBackground="@drawable/tab_indicator"
        app:tabGravity="center"
        app:tabIndicatorColor="@color/orange_500"
        app:tabSelectedTextColor="@color/orange_500"
        app:tabTextColor="@color/white" />

    <!-- Header com controles -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@drawable/gradient_background">

        <!-- Botão voltar -->
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            android:contentDescription="Voltar"
            app:tint="@color/white" />

        <!-- Informações da imagem -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp"
            android:layout_gravity="center_vertical">

            <!-- Nome do arquivo -->
            <TextView
                android:id="@+id/tvFileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Imagem.jpg"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Tamanho e tipo -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvFileSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.2 MB"
                    android:textSize="12sp"
                    android:textColor="@color/white_70"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tvImageType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Imagem Geral"
                    android:textSize="12sp"
                    android:textColor="@color/white_70" />

            </LinearLayout>

        </LinearLayout>

        <!-- Contador de imagens -->
        <TextView
            android:id="@+id/tvImageCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 de 3"
            android:textSize="14sp"
            android:textColor="@color/white"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="16dp" />

        <!-- Botão compartilhar -->
        <ImageButton
            android:id="@+id/btnShare"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_share"
            android:contentDescription="Compartilhar"
            app:tint="@color/white" />

        <!-- Botão informações -->
        <ImageButton
            android:id="@+id/btnInfo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_info"
            android:contentDescription="Informações"
            app:tint="@color/white" />

    </LinearLayout>

</RelativeLayout>
