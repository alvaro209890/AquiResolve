<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    tools:context=".OrderDetailsActivity">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary_color"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary_color"
            app:layout_scrollFlags="scroll|exitUntilCollapsed">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="12dp"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Detalhes do Pedido"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center" />

                <ImageView
                    android:id="@+id/btnMore"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_more"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="12dp"
                    app:tint="@color/white" />

            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Conteúdo Principal -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Status do Pedido -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_color"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:id="@+id/ivServiceIcon"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_plumber"
                            android:background="@drawable/circle_background_primary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginEnd="16dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvServiceNiche"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Encanador"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/tvOrderDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="15/12/2024 às 14:30"
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/tvOrderProtocol"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Protocolo: AR-2024.12.01-14:30:22-1234"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="2dp"
                                android:fontFamily="monospace" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PENDENTE"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:background="@drawable/status_pending_background"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="8dp" />

                    </LinearLayout>

                    <!-- Badges -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:id="@+id/tvEmergency"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🚨 EMERGÊNCIA"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/error_color"
                            android:background="@drawable/emergency_badge_background"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp"
                            android:layout_marginEnd="8dp"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tvServiceType"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💰 PREÇO FIXO"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_color"
                            android:background="@drawable/service_type_badge_background"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp" />

                    </LinearLayout>

                    <!-- Preço -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Preço:"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tvPrice"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="R$ 65,00"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_color"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Descrição -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_color"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Descrição do Problema"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Preciso trocar a torneira da pia da cozinha que está vazando há alguns dias. A torneira é antiga e precisa ser substituída por uma nova."
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:lineSpacingExtra="4dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Endereço -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_color"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Endereço do Serviço"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_location"
                            app:tint="@color/gray_500"
                            android:layout_marginEnd="12dp" />

                        <TextView
                            android:id="@+id/tvAddress"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Rua das Flores, 123 - São Paulo/SP"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvComplement"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Apto 45 - Bloco B"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginStart="32dp"
                        android:visibility="gone" />

                    <!-- Distância e mapa -->
                    <TextView
                        android:id="@+id/tvDistance"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Distância: --"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginTop="12dp"
                        android:visibility="gone" />

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardMap"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">

                        <org.osmdroid.views.MapView
                            android:id="@+id/mapOrder"
                            android:layout_width="match_parent"
                            android:layout_height="220dp" />
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Imagens -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardImages"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_color"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Imagens do Problema"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvImages"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Prestador (se atribuído) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardProvider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_color"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvCounterpartHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Prestador Atribuído"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/ivProviderPhoto"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_person"
                            android:background="@drawable/circle_background_secondary"
                            android:padding="12dp"
                            app:tint="@color/white"
                            android:layout_marginEnd="16dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvProviderName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="João Silva"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:id="@+id/tvProviderRating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⭐ 4.8 (127 avaliações)"
                                android:textSize="14sp"
                                android:textColor="@color/text_secondary" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnContactProvider"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Contatar"
                            android:textSize="12sp"
                            app:cornerRadius="8dp"
                            android:backgroundTint="@color/primary_color"
                            android:textColor="@color/white"
                            android:padding="8dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Código de Finalização (apenas para cliente quando pedido aceito) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardVerificationCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/success_color"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔐 Código de Finalização"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Guarde este código. O prestador irá solicitá-lo ao finalizar o serviço."
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/surface_color">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="16dp"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvVerificationCode"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="000000"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary_color"
                                android:fontFamily="monospace"
                                android:gravity="center" />

                            <ImageView
                                android:id="@+id/btnCopyCode"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@android:drawable/ic_menu_share"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:padding="6dp"
                                app:tint="@color/primary_color" />

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Aviso sobre confirmação de serviço -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@color/surface_highlight">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="⚠️ IMPORTANTE: Ao fornecer este código para o prestador, você está confirmando que o serviço foi realizado completamente e sem danos à sua residência."
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary_color"
                            android:padding="12dp"
                            android:lineSpacingExtra="4dp"
                            android:gravity="center_vertical" />

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Informações de Cancelamento -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCancellationInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_color"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pedido Cancelado"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/error_color"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tvCancelledAt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cancelado em --"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvCancelledBy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Por: --"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:id="@+id/tvCancellationReason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Motivo: --"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="12dp" />

                    <!-- Informações sobre reembolso (apenas para cancelamento pelo cliente) -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardRefundInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:cardCornerRadius="8dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/surface_success"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/success_color"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvRefundInfo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="💳 O valor pago será reembolsado automaticamente em até 24 horas."
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/success_color"
                            android:padding="12dp"
                            android:lineSpacingExtra="2dp"
                            android:gravity="center_vertical" />

                    </com.google.android.material.card.MaterialCardView>

                    <!-- Botão de solicitar reembolso (cliente, pedido pago sem solicitação) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRequestRefund"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Solicitar reembolso"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/primary_color"
                        app:cornerRadius="10dp"
                        android:layout_marginTop="12dp"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Cotações (para serviços complexos) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardQuotes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/surface_color"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cotações Recebidas"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/tvQuotesCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3 propostas"
                            android:textSize="14sp"
                            android:textColor="@color/secondary_color" />

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvQuotes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Ações -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">

                <!-- Botão de Ação Principal -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPrimaryAction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ver Cotações"
                    android:textSize="16sp"
                    app:cornerRadius="8dp"
                    android:backgroundTint="@color/primary_color"
                    android:textColor="@color/white"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp" />

                <!-- Botão Secundário -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSecondaryAction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cancelar Pedido"
                    android:textSize="14sp"
                    app:cornerRadius="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:textColor="@color/error_color"
                    app:strokeColor="@color/error_color"
                    android:padding="12dp"
                    android:minHeight="48dp"
                    android:visibility="visible" />

                <!-- Botão Recorrer (visível apenas para completed/cancelled) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAppeal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Recorrer ao Serviço"
                    android:textSize="14sp"
                    app:cornerRadius="8dp"
                    app:icon="@drawable/ic_help"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:textColor="@color/primary_color"
                    app:strokeColor="@color/primary_color"
                    android:padding="12dp"
                    android:minHeight="48dp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Estado de Carregamento -->
    <LinearLayout
        android:id="@+id/loadingState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/background_color"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            app:indicatorColor="@color/primary_color"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Carregando detalhes do pedido..."
            android:textSize="16sp"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout> 