<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    tools:context=".ChecklistActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/secondary_color"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/secondary_color">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_back"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="12dp"
                    app:tint="@color/white" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Checklist do Serviço"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvStep"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1/2"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:paddingEnd="16dp" />

            </LinearLayout>

        </androidx.appcompat.widget.Toolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Progress Indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <View
                    android:id="@+id/vProgress1"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/circle_background_secondary" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="4dp"
                    android:layout_weight="1"
                    android:id="@+id/vProgressLine"
                    android:background="@color/gray_300"
                    android:layout_marginHorizontal="4dp" />

                <View
                    android:id="@+id/vProgress2"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/circle_background_gray" />

            </LinearLayout>

            <!-- Card: Contexto do pedido (referência, somente leitura) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOrderContext"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/surface_color"
                app:strokeColor="@color/secondary_color"
                app:strokeWidth="1dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 Pedido em atendimento"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/secondary_color"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tvContextService"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvContextClient"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tvContextAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp"
                        android:visibility="gone" />
                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Step 1: Chegada ao local -->
            <LinearLayout
                android:id="@+id/layoutStep1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Card: Descrição do Serviço -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface_color"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Descrição do Serviço"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="16dp" />

                        <CheckBox
                            android:id="@+id/cbServiceElectric"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Elétrico"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbServicePlumber"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Encanador"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbServiceClog"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Desentupimento"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbServiceCheckup"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Check-Up"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbServiceWaterTankCleaning"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Limpeza de Caixa d'água"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbServiceGutterCleaning"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Limpeza de Calhas e Rufos"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbServiceGreaseTrapCleaning"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Limpeza de Caixa de Gordura"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbServiceLocksmith"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Chaveiro"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbServiceFanInstallation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Instalação de ventilador"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface_color"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1. Chegada ao Local"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="16dp" />

                        <CheckBox
                            android:id="@+id/cbClientPresent"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Cliente presente no local?"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbServiceMatches"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Serviço corresponde ao solicitado?"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbVisibleDamage"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Existem avarias visíveis antes do início?"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbMaterialAvailable"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Material necessário disponível?"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbMaterialsUsed"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Foi usado material ou suprimento específico no reparo?"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilMaterialsDescription"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:hint="Quais materiais/suprimentos foram usados?"
                            android:visibility="gone">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMaterialsDescription"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="80dp"
                                android:gravity="top"
                                android:inputType="textMultiLine|textCapSentences"
                                android:textSize="14sp" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <CheckBox
                            android:id="@+id/cbClientObservations"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Houve alguma observação do cliente?"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Card: Avarias pré-existentes -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface_color"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Avarias pré-existentes"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="6dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Informe avarias ou condições existentes antes do início do serviço para conhecimento do beneficiário."
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="12dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:hint="Descreva as avarias (deixe em branco se não houver)">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPreExistingDamages"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="80dp"
                                android:gravity="top"
                                android:textSize="14sp"
                                android:inputType="textMultiLine" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface_color"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2. Execução do Serviço"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="16dp" />

                        <CheckBox
                            android:id="@+id/cbExecutedAsRequested"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Serviço executado conforme solicitado?"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbAdditionalService"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Foi necessário serviço adicional?"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbPartsReplaced"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Houve troca de peças?"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbValueChanged"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Houve alteração no valor?"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbServiceCompleted"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Serviço concluído com sucesso?"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <CheckBox
                            android:id="@+id/cbCleanAfterService"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Local limpo após execução?"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface_color"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Descrição Detalhada do Serviço Realizado"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Descreva exatamente o que foi executado no local."
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="12dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:hint="Descrição do serviço realizado">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etExecutionDescription"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="120dp"
                                android:gravity="top"
                                android:textSize="14sp"
                                android:inputType="textMultiLine" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Card: O problema foi solucionado? -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface_color"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="O problema foi solucionado?"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="12dp" />

                        <RadioGroup
                            android:id="@+id/rgProblemResolution"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <RadioButton
                                android:id="@+id/rbResolved"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Sim, concluído com sucesso."
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:layout_marginBottom="8dp" />

                            <RadioButton
                                android:id="@+id/rbReturnNeeded"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Não, mas haverá retorno."
                                android:textSize="14sp"
                                android:textColor="@color/text_primary"
                                android:layout_marginBottom="8dp" />

                            <RadioButton
                                android:id="@+id/rbNotResolved"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Não, e não haverá retorno."
                                android:textSize="14sp"
                                android:textColor="@color/text_primary" />

                        </RadioGroup>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Card: Observações -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface_color"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Observações"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="12dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:hint="Observações adicionais">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etObservations"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:minHeight="90dp"
                                android:gravity="top"
                                android:textSize="14sp"
                                android:inputType="textMultiLine" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Card: Declaração de concordância -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/surface_color"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <CheckBox
                            android:id="@+id/cbDeclarationAccepted"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Declaro que concordo com as informações prestadas por mim, as quais são verdadeiras e autênticas, e autorizo o serviço com base nessas informações."
                            android:textSize="14sp"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Step 2: Fotos (inicialmente oculto) -->
            <LinearLayout
                android:id="@+id/layoutStep2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📷 Fotos do Serviço"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="16dp" />

            </LinearLayout>

            <!-- Resumo do que falta preencher -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPendingSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/orange_50"
                app:strokeColor="@color/primary_color"
                app:strokeWidth="1dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvPendingSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingExtra="2dp"
                    android:padding="14dp" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Botões -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="32dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNext"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Próximo: Fotos"
                    android:textSize="16sp"
                    app:cornerRadius="8dp"
                    android:backgroundTint="@color/secondary_color"
                    android:textColor="@color/white"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSaveDraft"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Salvar Rascunho"
                    android:textSize="14sp"
                    app:cornerRadius="8dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:textColor="@color/text_secondary"
                    app:strokeColor="@color/gray_300"
                    android:padding="12dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
