rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasContentType() {
      return request.resource != null
        && request.resource.contentType != null;
    }

    function isImageUpload() {
      return hasContentType()
        && request.resource.contentType.matches('image/.*');
    }

    function isImageOrPdfUpload() {
      return hasContentType()
        && (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType == 'application/pdf'
        );
    }

    function sizeWithin(limitBytes) {
      return request.resource != null
        && request.resource.size <= limitBytes;
    }

    function ownerCanModifyImage(userId, maxBytes) {
      return isOwner(userId)
        && (
          request.resource == null ||
          (isImageUpload() && sizeWithin(maxBytes))
        );
    }

    function ownerCanModifyImageOrPdf(userId, maxBytes) {
      return isOwner(userId)
        && (
          request.resource == null ||
          (isImageOrPdfUpload() && sizeWithin(maxBytes))
        );
    }

    function signedInCanModifyImage(maxBytes) {
      return isSignedIn()
        && (
          request.resource == null ||
          (isImageUpload() && sizeWithin(maxBytes))
        );
    }

    function signedInCanModifyImageOrPdf(maxBytes) {
      return isSignedIn()
        && (
          request.resource == null ||
          (isImageOrPdfUpload() && sizeWithin(maxBytes))
        );
    }

    // ===== FOTOS DE PERFIL =====
    match /profile_images/{userId}/{fileName} {
      allow read: if isOwner(userId);
      allow write: if ownerCanModifyImage(userId, 10 * 1024 * 1024);
    }

    // ===== PASTAS LEGADAS (acesso amplo para compatibilidade) =====
    match /profiles/{fileName} {
      allow read: if isSignedIn();
      allow write: if signedInCanModifyImage(10 * 1024 * 1024);
    }

    match /images/{fileName} {
      allow read: if isSignedIn();
      allow write: if signedInCanModifyImage(10 * 1024 * 1024);
    }

    // ===== DOCUMENTOS GERAIS =====
    match /documents/{fileName} {
      allow read: if isSignedIn();
      allow write: if signedInCanModifyImageOrPdf(10 * 1024 * 1024);
    }

    // ===== IMAGENS DE SERVIÇOS =====
    match /service_images/{serviceId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if signedInCanModifyImage(10 * 1024 * 1024);
    }

    // ===== BANNERS DA HOME (carrossel; upload pelo painel admin) =====
    match /banner_images/{fileName} {
      allow read: if isSignedIn();
      allow write: if signedInCanModifyImage(10 * 1024 * 1024);
    }

    // ===== IMAGENS DE CHAT =====
    match /chat_images/{orderId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if signedInCanModifyImage(10 * 1024 * 1024);
    }

    match /chats/{orderId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if signedInCanModifyImage(10 * 1024 * 1024);
    }

    // ===== IMAGENS DE PEDIDOS =====
    match /order_images/{orderId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if signedInCanModifyImage(10 * 1024 * 1024);
    }

    match /Pedidos/{orderId}/{fileName} {
      allow read: if isSignedIn();
      allow write: if signedInCanModifyImage(10 * 1024 * 1024);
    }

    match /orders/{orderId}/images/{fileName} {
      allow read: if isSignedIn();
      allow write: if signedInCanModifyImage(10 * 1024 * 1024);
    }

    match /orders/{orderId}/documents/{fileName} {
      allow read: if isSignedIn();
      allow write: if signedInCanModifyImageOrPdf(10 * 1024 * 1024);
    }

    // ===== DOCUMENTOS POR USUÁRIO =====
    match /Documentos/{userId}/{fileName} {
      allow read: if isOwner(userId);
      allow write: if ownerCanModifyImageOrPdf(userId, 10 * 1024 * 1024);
    }

    match /documents/{userId}/{fileName} {
      allow read: if isOwner(userId);
      allow write: if ownerCanModifyImageOrPdf(userId, 10 * 1024 * 1024);
    }

    match /provider_documents/{userId}/{fileName} {
      allow read: if isOwner(userId);
      allow write: if ownerCanModifyImageOrPdf(userId, 10 * 1024 * 1024);
    }

    // ===== SELFIES =====
    match /selfies/{userId}/{fileName} {
      allow read: if isOwner(userId);
      allow write: if ownerCanModifyImage(userId, 5 * 1024 * 1024);
    }

    match /Selfie/{userId}/{fileName} {
      allow read: if isOwner(userId);
      allow write: if ownerCanModifyImage(userId, 5 * 1024 * 1024);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
