rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de perfil
    match /profile_images/{userId}/{fileName} {
      // Todos logados podem ver
      allow read: if request.auth != null;
      // Apenas o dono pode atualizar sua foto e apenas imagens
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.contentType.matches('image/.*');
    }

    // Imagens de serviços
    match /service_images/{serviceId}/{fileName} {
      // Todos logados podem ver
      allow read: if request.auth != null;
      // Qualquer usuário logado pode enviar
      allow write: if request.auth != null && request.resource.contentType.matches('image/.*');
    }

    // Imagens do chat (associadas ao pedido) - pasta antiga
    // Regras simplificadas: auth + contentType (evita falha do get() no Firestore)
    match /chat_images/{orderId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.contentType.matches('image/.*');
    }

    // Imagens do chat (associadas ao pedido) - pasta nova "chats/{orderId}/"
    // Regras simplificadas: auth + contentType (evita falha do get() no Firestore)
    match /chats/{orderId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.contentType.matches('image/.*');
    }

    // Imagens de pedidos
    // Regras simplificadas: auth + contentType (evita falha do get() no Firestore)
    match /order_images/{orderId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.contentType.matches('image/.*');
    }

    // Imagens de pedidos (pasta "Pedidos" para compatibilidade com bucket atual)
    // Regras simplificadas: auth + contentType (evita falha do get() no Firestore)
    match /Pedidos/{orderId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.contentType.matches('image/.*');
    }

            // Documentos de prestadores - pasta "Documentos"
            match /Documentos/{userId}/{fileName} {
              // Apenas o dono pode ver e enviar
              allow read, write: if request.auth != null && request.auth.uid == userId;
            }

            // Selfies de prestadores - pasta "selfies"
            match /selfies/{userId}/{fileName} {
              // Apenas o dono pode ver e enviar
              allow read, write: if request.auth != null && request.auth.uid == userId;
            }

            // Selfies de prestadores - pasta "Selfie" (compatibilidade)
            match /Selfie/{userId}/{fileName} {
              // Apenas o dono pode ver e enviar
              allow read, write: if request.auth != null && request.auth.uid == userId;
            }

            // Documentos de prestadores - pasta "provider_documents"
            match /provider_documents/{userId}/{fileName} {
              // Apenas o dono pode ver e enviar
              allow read, write: if request.auth != null && request.auth.uid == userId;
            }

            // Documentos gerais - pasta "documents"
            match /documents/{userId}/{fileName} {
              // Apenas o dono pode ver e enviar
              allow read, write: if request.auth != null && request.auth.uid == userId;
            }
  }
}
