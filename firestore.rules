rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════════
    // HELPERS — autenticação e papéis
    // ═══════════════════════════════════════════════════════════════════════════

    function isSignedIn() {
      return request.auth != null;
    }

    // Admin/operador autenticado via custom claim
    //   admin.auth().setCustomUserClaims(uid, { role: 'admin' })
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'operador'
      );
    }

    // Prestador autenticado no app mobile
    function isProvider() {
      return isSignedIn() && (
        request.auth.token.role == 'prestador' ||
        request.auth.token.role == 'provider'
      );
    }

    // Cliente autenticado no app mobile
    function isClient() {
      return isSignedIn() && (
        request.auth.token.role == 'cliente' ||
        request.auth.token.role == 'client'
      );
    }

    function isProviderOrAdmin() {
      return isProvider() || isAdmin();
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // HELPERS — validação de pedidos (app mobile)
    // ═══════════════════════════════════════════════════════════════════════════

    function isOrderClient() {
      return isSignedIn() && resource.data.clientId == request.auth.uid;
    }

    function isOrderAssignedProvider() {
      return isSignedIn() && resource.data.assignedProvider == request.auth.uid;
    }

    function orderDeleteAllowed() {
      return isAdmin() || (isSignedIn() && (
        resource.data.clientId == request.auth.uid ||
        resource.data.assignedProvider == request.auth.uid ||
        resource.data.clienteId == request.auth.uid
      ));
    }

    function orderPriceFieldsUnchanged() {
      return request.resource.data.estimatedPrice == resource.data.estimatedPrice
        && request.resource.data.providerCommission == resource.data.providerCommission;
    }

    function orderSensitiveAssignmentFieldsUnchanged() {
      // Usa get(...,null): em pedido recém-criado esses campos NÃO existem (a regra
      // validOrderCreate os proíbe), então acessá-los direto fazia o update legítimo
      // (ex.: gravar 'images' após criar, ou cancelar pedido ainda não atribuído)
      // ser NEGADO. Com get(...,null) ausente==ausente vira null==null (passa), mas
      // qualquer tentativa de ALTERAR o valor continua bloqueada.
      return request.resource.data.get('assignedProvider', null) == resource.data.get('assignedProvider', null)
        && request.resource.data.get('assignedProviderName', null) == resource.data.get('assignedProviderName', null)
        && request.resource.data.get('clientVerificationCode', null) == resource.data.get('clientVerificationCode', null)
        && request.resource.data.get('providerVerificationCode', null) == resource.data.get('providerVerificationCode', null);
    }

    function validOrderCreate() {
      return isSignedIn()
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.status == 'awaiting_payment'
        && request.resource.data.paymentStatus == 'awaiting_payment'
        && request.resource.data.estimatedPrice is number
        && request.resource.data.estimatedPrice > 0
        && request.resource.data.providerCommission is number
        && request.resource.data.providerCommission >= 0
        && request.resource.data.keys().hasAll([
          'clientId', 'clientName', 'protocol', 'serviceType', 'serviceName',
          'description', 'address', 'city', 'state', 'status', 'paymentStatus',
          'estimatedPrice', 'providerCommission', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'clientId', 'clientName', 'clientEmail', 'clientPhone', 'protocol',
          'serviceType', 'serviceName', 'description', 'address', 'zipCode',
          'complement', 'city', 'state', 'coordinates', 'scheduledDate',
          'preferredTimeSlot', 'images', 'cartCheckoutCode', 'cartItemId',
          'status', 'paymentStatus', 'estimatedPrice', 'finalPrice',
          'cartDiscountPercent', 'providerCommission', 'createdAt', 'updatedAt',
          'serviceCategory', 'originAddress', 'destinationAddress',
          'originLocation', 'destinationLocation', 'distanceKm'
        ]);
    }

    function validClientOrderUpdate() {
      return isOrderClient()
        && orderPriceFieldsUnchanged()
        && orderSensitiveAssignmentFieldsUnchanged()
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['images', 'updatedAt'])
          || (
            request.resource.data.status == 'cancelled'
            && request.resource.data.cancelledBy == 'client'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'cancelledAt', 'cancelledBy', 'cancellationReason',
              'updatedAt', 'refundStatus', 'refundRequestedAt'
            ])
          )
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'clientCompletionConfirmed', 'status', 'completedAt',
            'settlementStatus', 'settlementRequestedAt', 'updatedAt'
          ])
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'rating', 'review', 'reviewedAt', 'ratedAt',
            'qualityRating', 'punctualityRating', 'communicationRating',
            'cleanlinessRating', 'ratingTags', 'updatedAt'
          ])
        );
    }

    function validProviderAcceptUpdate() {
      return isSignedIn()
        && resource.data.status in ['distributing', 'pending', 'available']
        && (resource.data.assignedProvider == null || resource.data.assignedProvider == '')
        && request.resource.data.status == 'assigned'
        && request.resource.data.assignedProvider == request.auth.uid
        && request.resource.data.assignedProviderName is string
        && request.resource.data.clientVerificationCode is string
        && request.resource.data.providerVerificationCode is string
        && orderPriceFieldsUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'assignedProvider', 'assignedProviderName', 'status', 'assignedAt',
          'clientVerificationCode', 'providerVerificationCode',
          'verificationCodesGeneratedAt', 'updatedAt'
        ]);
    }

    function validProviderOrderUpdate() {
      return isOrderAssignedProvider()
        && orderPriceFieldsUnchanged()
        && (
          (
            resource.data.status == 'assigned'
            && request.resource.data.status == 'in_progress'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'startedAt', 'updatedAt'])
          )
          || request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'providerCompletionConfirmed', 'clientCompletionConfirmed', 'status',
            'completedAt', 'settlementStatus', 'settlementRequestedAt', 'updatedAt'
          ])
          || (
            request.resource.data.status == 'cancelled'
            && request.resource.data.cancelledBy == 'provider'
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status', 'cancelledAt', 'cancelledBy', 'cancellationReason', 'updatedAt'
            ])
          )
        );
    }

    // Permite que qualquer prestador autenticado marque um pedido como rejeitado
    // (adiciona seu UID ao array rejectedBy). Só em pedidos ainda não atribuídos.
    function validProviderRejectUpdate() {
      return isSignedIn()
        && resource.data.status in ['distributing', 'pending', 'available']
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['rejectedBy']);
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // adminmaster (dashboard — escrita apenas via Admin SDK, leitura bloqueada ao client)
    // ═══════════════════════════════════════════════════════════════════════════

    match /adminmaster/{document=**} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Configurações do app (escrita apenas via Admin SDK / dashboard)
    // ═══════════════════════════════════════════════════════════════════════════

    match /app_config/{configId} {
      allow read: if isSignedIn();
      allow write: if false; // Dashboard usa Admin SDK
    }

    // Banners do carrossel da Home — leitura por usuário autenticado;
    // escrita exclusiva via Admin SDK (painel /dashboard/configuracoes/banners).
    match /home_banners/{bannerId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Combos promocionais (vitrine) da Home — leitura por usuário autenticado;
    // escrita exclusiva via Admin SDK (painel /dashboard/servicos/combos).
    // O desconto cobrado continua sendo recalculado no carrinho pelo PromotionManager;
    // os campos de preço do combo são apenas exibição/curadoria.
    match /home_combos/{comboId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Parceiros patrocinadores exibidos na Home — leitura por usuário autenticado;
    // escrita exclusiva via Admin SDK (painel /dashboard/configuracoes/parceiros).
    match /partners/{partnerId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Impressões diárias dos banners de parceiros (limite de N clientes/dia por parceiro).
    // Doc id = `{partnerId}_{yyyy-MM-dd}` com { partnerId, date, count, clientIds[] }.
    // O cliente só pode somar o PRÓPRIO uid e manter count == clientIds.size() (ver
    // PartnerImpressionManager). Tradeoff aceito: é contador de vitrine/anúncio, não financeiro.
    match /partner_impressions/{docId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.clientIds
        && request.resource.data.count == request.resource.data.clientIds.size()
        && request.resource.data.clientIds.size() <= 100000;
      allow update: if isSignedIn()
        && request.auth.uid in request.resource.data.clientIds
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['count', 'clientIds', 'updatedAt'])
        && request.resource.data.count == request.resource.data.clientIds.size();
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Usuários
    // ═══════════════════════════════════════════════════════════════════════════

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId;
      allow update: if isAdmin()
        || (isOwner(userId) && (request.resource.data.uid == userId || resource.data.uid == null))
        // Recálculo da reputação do cliente após o prestador avaliá-lo num pedido
        // concluído (FirebaseOrderManager.updateClientAverageRatingFromReviews).
        // Restrito aos campos derivados de nota do cliente.
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['clientRating', 'clientTotalRatings', 'updatedAt']));
      allow delete: if isAdmin() || isOwner(userId);

      match /cashback_transactions/{txId} {
        allow read: if isOwner(userId);
        // escrita exclusiva via Admin SDK (painel/backend); cliente não pode creditar cashback a si mesmo
        allow write: if false;
      }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Prestadores
    // ═══════════════════════════════════════════════════════════════════════════

    match /providers/{providerId} {
      allow read: if isSignedIn();
      allow create: if isAdmin()
        || (isOwner(providerId) && request.resource.data.uid == providerId);
      allow update: if isAdmin()
        || (isOwner(providerId) && (request.resource.data.uid == providerId || resource.data.uid == null))
        // Recálculo da nota pública do prestador após o cliente avaliar um pedido
        // concluído (FirebaseOrderManager.updateProviderAverageRatingFromOrders).
        // Restrito aos campos derivados de nota — não permite alterar nada mais.
        || (isSignedIn()
            && request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['rating', 'totalRatings', 'updatedAt']));
      allow delete: if isAdmin() || isOwner(providerId);
    }

    match /provider_verifications/{verificationId} {
      allow read: if isSignedIn();
      // escrita exclusiva via Admin SDK (painel); prestador não deve criar sua própria entrada de verificação
      allow write: if false;
    }

    match /provider_documents/{documentId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.providerId == request.auth.uid
      );
      allow create: if isSignedIn() && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.providerId == request.auth.uid
      );
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.providerId == request.auth.uid
      ) && (
        request.resource.data.userId == request.auth.uid ||
        request.resource.data.providerId == request.auth.uid
      );
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.providerId == request.auth.uid
      );
    }

    match /provider_bank_data/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Solicitações de alteração de especialidades — prestador cria, admin aprova/rejeita via Admin SDK
    // Exige justificativa textual + fotos obrigatórias (documento, selfie, comprovantes)
    match /provider_specialty_requests/{requestId} {
      // Prestador lê suas próprias solicitações (para exibir o status no app)
      allow read: if isSignedIn() && resource.data.providerId == request.auth.uid;
      // Prestador cria a própria solicitação com status inicial pending + campos obrigatórios
      allow create: if isSignedIn()
        && request.resource.data.providerId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasAll([
          'providerId','providerName','requestedServices','currentServices',
          'justificationText','documentPhotoUrl','selfiePhotoUrl','proofPhotoUrls',
          'status','createdAt'
        ])
        && request.resource.data.justificationText is string
        && request.resource.data.justificationText.size() >= 20
        && request.resource.data.documentPhotoUrl is string
        && request.resource.data.documentPhotoUrl.size() > 0
        && request.resource.data.selfiePhotoUrl is string
        && request.resource.data.selfiePhotoUrl.size() > 0
        && request.resource.data.proofPhotoUrls is list
        && request.resource.data.proofPhotoUrls.size() >= 1
        && request.resource.data.proofPhotoUrls.size() <= 3;
      // Updates e deletes exclusivos via Admin SDK (dashboard)
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Pedidos (orders)
    // ═══════════════════════════════════════════════════════════════════════════

    match /orders/{orderId} {
      allow read: if isSignedIn();
      allow create: if validOrderCreate();
      allow update: if validClientOrderUpdate()
        || validProviderAcceptUpdate()
        || validProviderRejectUpdate()
        || validProviderOrderUpdate();
      allow delete: if orderDeleteAllowed();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /order_settlements/{settlementId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Campanhas promocionais de cashback — gerenciadas só pelo Admin SDK
    // (rotas /api/cashback-campaigns). Leitura liberada a usuários autenticados
    // para o app exibir campanhas ativas; escrita bloqueada no client SDK.
    match /cashback_campaigns/{campaignId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Checklists (top-level — app mobile)
    // ═══════════════════════════════════════════════════════════════════════════

    match /checklists/{orderId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.orderId == orderId;
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Chat
    // ═══════════════════════════════════════════════════════════════════════════

    match /chatRooms/{chatRoomId} {
      allow read: if isSignedIn()
        && resource.data.participants != null
        && resource.data.participants.hasAny([request.auth.uid]);
      allow create: if isSignedIn()
        && request.resource.data.participants != null
        && request.resource.data.participants.hasAny([request.auth.uid]);
      allow update: if isSignedIn()
        && resource.data.participants != null
        && resource.data.participants.hasAny([request.auth.uid]);
      allow delete: if isSignedIn()
        && resource.data.participants != null
        && resource.data.participants.hasAny([request.auth.uid]);
    }

    match /chats/{chatId} {
      allow read, write: if isSignedIn();
    }

    // Conversas consolidadas para a Central Operacional do painel admin.
    // Escrita pelo app (cliente/prestador) ao enviar mensagem; leitura pelo admin e pelas partes.
    match /chatConversations/{orderId} {
      allow read, write: if isSignedIn();
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Chat Base ↔ Cliente — comunicação bidirecional admin↔cliente (promoções,
    // avisos, atualizações). Doc por cliente (id == uid). Metadata só Admin SDK
    // (preserva contadores e estado de leitura). Cliente cria mensagens próprias
    // com senderType='client'; admin envia via Admin SDK.
    // ═══════════════════════════════════════════════════════════════════════════

    match /client_chats/{clientId} {
      allow read: if isOwner(clientId);
      allow write: if false; // metadata só Admin SDK

      match /messages/{messageId} {
        allow read: if isOwner(clientId);
        // Cliente pode criar a própria mensagem (senderType='client').
        // Admin SDK cria as do admin (bypassa rules).
        allow create: if isOwner(clientId)
          && request.resource.data.senderType == 'client'
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow update, delete: if false; // só Admin SDK
      }
    }

    // Histórico de broadcasts (snapshot de cada disparo em massa). Só Admin SDK.
    match /client_chat_broadcasts/{broadcastId} {
      allow read, write: if false;
    }

    // Chat Base ↔ Prestador (espelha client_chats). Metadata só Admin SDK; o prestador lê o
    // próprio chat e pode criar a própria mensagem (senderType='provider').
    match /provider_chats/{providerId} {
      allow read: if isOwner(providerId);
      allow write: if false; // metadata só Admin SDK

      match /messages/{messageId} {
        allow read: if isOwner(providerId);
        allow create: if isOwner(providerId)
          && request.resource.data.senderType == 'provider'
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;
        allow update, delete: if false; // só Admin SDK
      }
    }

    // Histórico de broadcasts para prestadores. Só Admin SDK.
    match /provider_chat_broadcasts/{broadcastId} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Notificações
    // ═══════════════════════════════════════════════════════════════════════════

    match /notifications/{notificationId} {
      allow read, update: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow delete: if false;
      // criação exclusiva via Admin SDK (dashboard + auto-notificações de status)
      allow create: if false;
    }

    match /userTokens/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Carrinho
    // ═══════════════════════════════════════════════════════════════════════════

    match /carts/{userId} {
      allow read, write: if isOwner(userId);

      match /items/{itemId} {
        allow read, write: if isOwner(userId);
      }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Privacidade / LGPD
    // ═══════════════════════════════════════════════════════════════════════════

    match /privacy_settings/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /data_exports/{exportId} {
      allow create: if isSignedIn();
      allow read, delete: if isSignedIn()
        && resource.data.userData != null
        && resource.data.userData.uid == request.auth.uid;
    }

    match /lgpd_consents/{consentId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    match /lgpd_requests/{requestId} {
      allow create: if isSignedIn();
      allow read: if isOwner(resource.data.userId);
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Catálogo de serviços
    // ═══════════════════════════════════════════════════════════════════════════

    // Catálogo de serviços — leitura por qualquer usuário autenticado (app + painel);
    // escrita EXCLUSIVA via Admin SDK (rota /api/catalog do painel). Antes qualquer
    // usuário autenticado podia adulterar o catálogo global; agora não.
    match /service_categories/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /service_types/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Serviços do catálogo (nicho + valor + % do prestador). Um doc por serviço.
    // Leitura por app + painel; escrita EXCLUSIVA via Admin SDK (/api/catalog/services).
    match /catalog_services/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /service_providers/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /provider_reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.clientId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.clientId == request.auth.uid;
    }

    // Avaliação do prestador sobre o cliente (mão inversa do provider_reviews).
    // O autor é o prestador; o doc id é o orderId (uma avaliação por pedido).
    match /client_reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.providerId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.providerId == request.auth.uid;
    }

    match /service_quotes/{quoteId} {
      allow read: if isSignedIn();
    }

    match /user_favorites/{favoriteId} {
      allow read, update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Endereços salvos
    // ═══════════════════════════════════════════════════════════════════════════

    match /saved_addresses/{addressId} {
      allow read: if isSignedIn()
        && (resource.data.clientId == request.auth.uid || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && (request.resource.data.clientId == request.auth.uid || request.resource.data.userId == request.auth.uid);
      allow update: if isSignedIn()
        && (resource.data.clientId == request.auth.uid || resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn()
        && (resource.data.clientId == request.auth.uid || resource.data.userId == request.auth.uid);
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Alertas operacionais — Central Operacional do painel admin.
    // Leitura e escrita por qualquer usuário autenticado (client SDK do painel).
    // Não usamos isAdmin() aqui porque os administradores do painel não recebem
    // custom claim por padrão — isSignedIn() é suficiente dado que a coleção é
    // interna e não expõe dados sensíveis de clientes.
    // ═══════════════════════════════════════════════════════════════════════════

    match /operationalAlerts/{alertId} {
      allow read, write: if isSignedIn();
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Chats da IA (Hello) — cada usuário vê/só os próprios chats
    // ═══════════════════════════════════════════════════════════════════════════

    match /ai_chats/{chatId} {
      allow read, create, update: if isSignedIn()
        && request.auth.uid == request.resource.data.userId;
      allow read, update: if isSignedIn()
        && request.auth.uid == resource.data.userId;

      match /messages/{msgId} {
        allow read, create: if isSignedIn()
          && request.auth.uid == get(/databases/$(database)/documents/ai_chats/$(chatId)).data.userId;
      }
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Logs de auditoria — escrita exclusiva via Admin SDK (dashboard)
    // ═══════════════════════════════════════════════════════════════════════════

    match /adminLogs/{logId} {
      allow read, write: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════
    // Fallback — nega tudo não coberto acima
    // ═══════════════════════════════════════════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
